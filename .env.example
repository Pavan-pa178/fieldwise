# Copy this file to .env (or export these in your shell) to switch
# FieldWise from offline mock mode to live Gemini-powered mode.
#
# 🚨 NEVER commit a real .env file or paste a real key into source code.
# This .env.example file should be the only one tracked in git.

# "mock" (default, free, offline) or "gemini" (live AI, requires API key)
FIELDWISE_LLM_MODE=mock

# Required ONLY if FIELDWISE_LLM_MODE=gemini.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
